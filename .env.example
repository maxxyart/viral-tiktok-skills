# Required for BOTH skills — get a key at https://scrapecreators.com
SCRAPE_CREATORS_API_KEY=

# For carousel-account-patterns slide OCR and hook-analysis FAST mode
# (default hook-analysis mode needs no vision key — Claude reads covers natively)
# Get a key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Optional: automatic fallback when Gemini is unavailable (e.g. geo-blocked)
# Get a key at https://console.x.ai
XAI_API_KEY=

# Optional tuning — defaults are sensible, uncomment to override
# SCRAPER_CONCURRENCY=1
# SCRAPER_INTERVAL_CAP=2
# SCRAPER_INTERVAL_MS=1000
# SCRAPER_REQUEST_TIMEOUT_MS=30000
